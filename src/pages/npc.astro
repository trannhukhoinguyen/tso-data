---
import MainLayout from '../layouts/Layout.astro';
// Đưa thẳng file JSON tĩnh thành một URL để client tự fetch (vừa nhẹ HTML vừa mượt)
import npcsJsonUrl from '../data/npcs.json?url';
---

<MainLayout title="Tra cứu NPC - TS Online">
    <div class="border-b border-gray-700 bg-slate-900 sticky top-0 z-10 w-full">
        <div class="max-w-7xl mx-auto flex space-x-2 p-4 overflow-x-auto whitespace-nowrap scrollbar-none snap-x">
            <a href="/" class="px-4 py-2 rounded bg-blue-600 text-white font-medium snap-xminor">Bãi Quái</a>
            <a href="/npc" class="px-4 py-2 rounded text-green-300 hover:bg-slate-800 snap-xminor">NPC</a>
            <a href="/items" class="px-4 py-2 rounded text-orange-300 hover:bg-slate-800 snap-xminor">Vật Phẩm</a>
            <a href="/map" class="px-4 py-2 rounded text-red-300 hover:bg-slate-800 snap-xminor">Bản Đồ</a>
            <a href="/skills" class="px-4 py-2 rounded text-purple-300 hover:bg-slate-800 snap-xminor">Kỹ Năng</a>
            <a href="/warp" class="px-4 py-2 rounded text-indigo-300 hover:bg-slate-800 snap-xminor">Warp</a>
            <a href="/training" class="px-4 py-2 rounded text-rose-300 hover:bg-slate-800 snap-xminor">Training</a>
            <a href="/quests" class="px-4 py-2 rounded text-zinc-300 hover:bg-slate-800 snap-xminor">Quest</a>
        </div>
    </div>

    <main class="max-w-7xl mx-auto p-4 text-white">
        <h1 class="text-2xl font-bold mb-4">Danh sách NPC (Gộp trùng tên)</h1>

        <div class="flex flex-col md:flex-row gap-4 mb-6">
            <input
                    type="text"
                    id="search-input"
                    placeholder="Nhập tên NPC cần tìm..."
                    class="flex-1 bg-slate-800 text-white border border-gray-700 rounded px-4 py-2 focus:outline-none focus:border-blue-500"
            />

            <select
                    id="element-filter"
                    class="bg-slate-800 text-white border border-gray-700 rounded px-4 py-2 focus:outline-none focus:border-blue-500"
            >
                <option value="">Tất cả hệ</option>
                <option value="Địa">Địa</option>
                <option value="Thủy">Thủy</option>
                <option value="Hỏa">Hỏa</option>
                <option value="Phong">Phong</option>
            </select>
        </div>

        <div class="overflow-x-auto border border-gray-700 rounded-lg shadow bg-slate-900">
            <table class="min-w-full divide-y divide-gray-700 text-left text-sm">
                <thead class="bg-slate-800 text-gray-300 uppercase font-semibold text-xs tracking-wider">
                <tr>
                    <th class="px-4 py-3">Tên NPC</th>
                    <th class="px-4 py-3">Hệ</th>
                    <th class="px-4 py-3 text-center">Level</th>
                    <th class="px-4 py-3 text-center">HP</th>
                    <th class="px-4 py-3 text-center">SP</th>
                    <th class="px-4 py-3">Kỹ Năng</th>
                    <th class="px-4 py-3">Bản Đồ Xuất Hiện (Map ID)</th>
                </tr>
                </thead>
                <tbody id="npc-table-body" class="divide-y divide-gray-800">
                <tr>
                    <td colspan="7" class="text-center py-8 text-gray-400">Đang tải dữ liệu NPC...</td>
                </tr>
                </tbody>
            </table>
        </div>

        <div id="no-result" class="text-center text-gray-400 py-8 hidden">
            Không tìm thấy NPC phù hợp với bộ lọc.
        </div>
    </main>
</MainLayout>

<script define:vars={{ npcsJsonUrl }}>
    let groupedNpcs = [];

    // Mảng màu đan xen dành cho các thẻ Map ID
    const tagColors = [
        'bg-gray-700 text-gray-200 border-gray-600',
        'bg-slate-700 text-slate-200 border-slate-600',
        'bg-zinc-700 text-zinc-200 border-zinc-600',
        'bg-neutral-700 text-neutral-200 border-neutral-600'
    ];

    function removeVietnameseTones(str) {
        return str.normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/đ/g, "d").replace(/Đ/g, "D");
    }

    // Khởi tạo tải dữ liệu và gộp các record trùng tên
    async function init() {
        try {
            const response = await fetch(npcsJsonUrl);
            const rawData = await response.json();

            // Sử dụng Map để gộp các NPC trùng tên
            const npcMap = new Map();

            rawData.forEach(npc => {
                // Lấy danh sách ID bản đồ từ mảng locations của record này
                const currentMapIds = npc.locations ? npc.locations.map(loc => loc.mapId) : [];

                if (npcMap.has(npc.name)) {
                    // Nếu đã tồn tại NPC trùng tên, tiến hành gộp Map ID
                    const existing = npcMap.get(npc.name);
                    currentMapIds.forEach(id => {
                        if (!existing.mapIds.includes(id)) {
                            existing.mapIds.push(id);
                        }
                    });
                } else {
                    // Nếu chưa có, tạo bản ghi gộp mới
                    npcMap.set(npc.name, {
                        name: npc.name,
                        elementName: npc.elementName || 'Vô',
                        level: npc.level,
                        hp: npc.hp,
                        sp: npc.sp,
                        skills: npc.skills || [],
                        mapIds: currentMapIds
                    });
                }
            });

            // Chuyển Map thành mảng để thao tác tìm kiếm / hiển thị
            groupedNpcs = Array.from(npcMap.values());

            // Render 50 dòng đầu tiên lên table
            renderTable(groupedNpcs.slice(0, 50));

            // Kích hoạt lắng nghe sự kiện
            document.getElementById('search-input').addEventListener('input', filterTable);
            document.getElementById('element-filter').addEventListener('change', filterTable);

        } catch (error) {
            console.error("Lỗi khi load dữ liệu NPC:", error);
            document.getElementById('npc-table-body').innerHTML = `<tr><td colspan="7" class="text-center py-8 text-red-400">Không thể tải dữ liệu.</td></tr>`;
        }
    }

    // Hàm sinh chuỗi các tag màu đan xen cho Map ID
    function generateMapTags(mapIds) {
        if (!mapIds || mapIds.length === 0) {
            return `<span class="text-xs text-gray-500 italic">Không rõ nơi bắt</span>`;
        }

        return mapIds.map((id, index) => {
            // Chọn màu đan xen tuần hoàn dựa trên vị trí index
            const colorClass = tagColors[index % tagColors.length];
            return `<span class="inline-block text-xs font-mono px-2 py-0.5 rounded border ${colorClass} mr-1 mb-1 shadow-sm">${id}</span>`;
        }).join('');
    }

    // Hàm render dữ liệu mảng vào thẻ <tbody>
    function renderTable(list) {
        const tbody = document.getElementById('npc-table-body');
        const noResult = document.getElementById('no-result');

        if (list.length === 0) {
            tbody.innerHTML = '';
            noResult.classList.remove('hidden');
            return;
        }
        noResult.classList.add('hidden');

        tbody.innerHTML = list.map(npc => {
            // Định màu sắc riêng cho chữ của hệ tương ứng
            let elementColor = 'text-amber-400'; // Địa
            if (npc.elementName === 'Thủy') elementColor = 'text-blue-400';
            if (npc.elementName === 'Hỏa') elementColor = 'text-red-400';
            if (npc.elementName === 'Phong') elementColor = 'text-green-400';

            // Xử lý render danh sách kỹ năng của NPC thành chuỗi ngắn gọn
            const skillString = npc.skills.length > 0
                ? npc.skills.map(s => s.name).join(', ')
                : '<span class="text-gray-600">-</span>';

            return `
        <tr class="hover:bg-slate-800 transition-colors">
          <td class="px-4 py-3 font-semibold text-yellow-400">${npc.name}</td>
          <td class="px-4 py-3 font-medium ${elementColor}">${npc.elementName}</td>
          <td class="px-4 py-3 text-center">${npc.level}</td>
          <td class="px-4 py-3 text-center text-emerald-400">${npc.hp.toLocaleString()}</td>
          <td class="px-4 py-3 text-center text-cyan-400">${npc.sp.toLocaleString()}</td>
          <td class="px-4 py-3 text-gray-300 max-w-xs truncate" title="${skillString}">${skillString}</td>
          <td class="px-4 py-3 max-w-md">${generateMapTags(npc.mapIds)}</td>
        </tr>
      `;
        }).join('');
    }

    // Hàm lọc tìm kiếm
    function filterTable() {
        const keyword = removeVietnameseTones(document.getElementById('search-input').value.toLowerCase().trim());
        const selectedElement = document.getElementById('element-filter').value;

        const filtered = groupedNpcs.filter(npc => {
            const matchKeyword = removeVietnameseTones(npc.name.toLowerCase()).includes(keyword);
            const matchElement = selectedElement === "" || npc.elementName === selectedElement;
            return matchKeyword && matchElement;
        });

        // Giới hạn hiển thị 150 dòng để tối ưu UI mượt mà
        renderTable(filtered.slice(0, 150));
    }

    // Chạy ứng dụng
    init();
</script>
