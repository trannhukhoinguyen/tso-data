---
import MainLayout from '../layouts/Layout.astro';
// Import trực tiếp dữ liệu JSON tại Server-side để truyền xuống Client
import questJsonUrl from '../data/quests.json?url';
import provincesData from '../data/provinces.json?url';
---

<MainLayout title="Tra cứu NPC - TS Online">
    <main class="max-w-7xl mx-auto p-4">
        <h1 class="text-2xl font-bold mb-4">Danh sách Quest</h1>

        <div class="flex flex-col md:flex-row gap-4 mb-6">
            <input
                    type="text"
                    id="search-input"
                    placeholder="Nhập tên Quest hoặc ID..."
                    class="flex-1 bg-slate-800 text-white border border-gray-700 rounded px-4 py-2 focus:outline-none focus:border-blue-500"
            />

            <select
                    id="province-filter"
                    class="bg-slate-800 text-white border border-gray-700 rounded px-4 py-2 focus:outline-none focus:border-blue-500"
            >
                <option value="">Tất cả Châu</option>
                <option value="u_chau">U Châu</option>
                <option value="du_chau">Dự Châu</option>
                <option value="ky_chau">Ký Châu</option>
                <option value="thanh_chau">Thanh Châu</option>
                <option value="duong_chau">Dương Châu</option>
            </select>
        </div>

        <div id="quest-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        </div>

        <div id="no-result" class="text-center text-gray-400 py-8 hidden">
            Không tìm thấy Quest phù hợp.
        </div>
    </main>
</MainLayout>

<script define:vars={{ questJsonUrl }}>
    let groupedQuests = [];
    // Mảng màu đan xen dành cho các thẻ Map ID
    const tagColors = [
        'bg-gray-700 text-gray-200 border-gray-600',
        'bg-slate-700 text-slate-200 border-slate-600',
        'bg-zinc-700 text-zinc-200 border-zinc-600',
        'bg-neutral-700 text-neutral-200 border-neutral-600'
    ];

    // Bản đồ mapping giữa Value trên UI và Tên Hệ trong database JSON
    const provinceMapping = {
        'u_chau': 'U Châu',
        'du_chau': 'Dự Châu',
        'ky_chau': 'Ký Châu',
        'thanh_chau': 'Thanh Châu',
        'duong_chau': 'Dương Châu',
        'nhi_chau': 'Nhị Châu',
        'giao_chau': 'Giao Châu',
        'duyen_chau': 'Duyện Châu',
        'tu_chau': 'Từ Châu',
        'tinh_chau': 'Tịnh Châu',
        'ich_chau': 'Ích Châu',
        'luong_chau': 'Lương Châu',
        'ung_chau': 'Ung Châu',
        'kinh_chau_bac': 'Kinh Châu Bắc',
        'kinh_chau_nam': 'Kinh Châu Nam',
        'ti_lo': 'Ti Lộ',
        'tay_vuc': 'Tây Vực',
        'quan_trung': 'Quan Trung',
        'quan_ngoai': 'Quan Ngoại',
        'tac_ngoai': 'Tắc Ngoại',
        'lieu_dong': 'Liêu Đông',
        'linh_nam': 'Lĩnh Nam',
        'nam_trung': 'Nam Trung',
        'oa_quoc': 'Oa Quốc',
        'cao_cu_le': 'Cao Cư Lệ',
        'bong_lai_tien_dao': 'Bồng Lai Tiên Đảo',
        'dia_phu': 'Địa Phủ',
        'tien_gioi': 'Tiên Giới'
    };

    function removeVietnameseTones(str) {
        return str.normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/đ/g, "d").replace(/Đ/g, "D");
    }

    // Khởi tạo tải dữ liệu và gộp các record trùng tên
    async function init() {
        try {
            const response = await fetch(questJsonUrl);
            const rawData = await response.json();

            // Sử dụng Map để gộp các NPC trùng tên
            const questMap = new Map();
            rawData.forEach(quest => {
                // Lấy danh sách ID bản đồ từ mảng locations của record này
                const currentMapIds = quest.locations ? quest.locations.map(loc => loc.mapId) : [];

                if (questMap.has(quest.name)) {
                    // Nếu đã tồn tại NPC trùng tên, tiến hành gộp Map ID
                    const existing = questMap.get(quest.name);
                    currentMapIds.forEach(id => {
                        if (!existing.mapIds.includes(id)) {
                            existing.mapIds.push(id);
                        }
                    });
                } else {
                    // Nếu chưa có, tạo bản ghi gộp mới
                    questMap.set(quest.name, {
                        name: quest.name,
                        elementName: quest.elementName || 'Vô',
                        level: quest.level,
                        hp: quest.hp,
                        sp: quest.sp,
                        skills: quest.skills || [],
                        mapIds: currentMapIds
                    });
                }
            });

            // Chuyển Map thành mảng để thao tác tìm kiếm / hiển thị
            groupedQuests = Array.from(questMap.values());

            // ĐỌC QUERY PARAM từ URL (?element=...)
            const urlParams = new URLSearchParams(window.location.search);
            const provinceParam = urlParams.get('province'); // Ví dụ: 'water'

            if (provinceParam && provinceMapping[provinceParam]) {
                // Gán ngược value vào thẻ select trên UI
                document.getElementById('province-filter').value = provinceParam;
            }

            // Gọi hàm filterTable lần đầu để vừa hiển thị vừa áp dụng bộ lọc từ URL (nếu có)
            filterTable();

            // Kích hoạt lắng nghe sự kiện khi user tương tác thủ công
            document.getElementById('search-input').addEventListener('input', filterTable);
            document.getElementById('element-filter').addEventListener('change', filterTable);

        } catch (error) {
            console.error("Lỗi khi load dữ liệu NPC:", error);
            document.getElementById('quest-table-body').innerHTML = `<tr><td colspan="7" class="text-center py-8 text-red-400">Không thể tải dữ liệu.</td></tr>`;
        }
    }

    // Hàm sinh chuỗi các tag màu đan xen cho Map ID
    function generateMapTags(mapIds) {
        if (!mapIds || mapIds.length === 0) {
            return `<span class="text-xs text-gray-500 italic">Không rõ nơi bắt</span>`;
        }

        return mapIds.map((id, index) => {
            const colorClass = tagColors[index % tagColors.length];
            return `<span class="inline-block text-xs font-mono px-2 py-0.5 rounded border ${colorClass} mr-1 mb-1 shadow-sm">${id}</span>`;
        }).join('');
    }

    // Hàm render dữ liệu mảng vào thẻ <tbody>
    function renderTable(list) {
        const tbody = document.getElementById('quest-table-body');
        const noResult = document.getElementById('no-result');

        if (list.length === 0) {
            tbody.innerHTML = '';
            noResult.classList.remove('hidden');
            return;
        }
        noResult.classList.add('hidden');
        tbody.innerHTML = list.map(quest => {
            // Định màu sắc riêng cho chữ của hệ tương ứng
            let elementColor = 'text-amber-400'; // Địa
            if (quest.elementName === 'Thủy') elementColor = 'text-blue-400';
            if (quest.elementName === 'Hỏa') elementColor = 'text-red-400';
            if (quest.elementName === 'Phong') elementColor = 'text-green-400';
            if (quest.elementName === 'Tâm') elementColor = 'text-purple-400'; // Thêm màu cho hệ Tâm

            const skillString = quest.skills.length > 0
                ? quest.skills.map(s => s.name).join(', ')
                : '<span class="text-gray-600">-</span>';

            return `
        <tr class="hover:bg-slate-800 transition-colors">
          <td class="px-4 py-3 font-semibold text-yellow-400">${quest.name}</td>
          <td class="px-4 py-3 font-medium ${elementColor}">${quest.elementName}</td>
          <td class="px-4 py-3 text-center">${quest.level}</td>
          <td class="px-4 py-3 text-center text-emerald-400">${quest.hp.toLocaleString()}</td>
          <td class="px-4 py-3 text-center text-cyan-400">${quest.sp.toLocaleString()}</td>
          <td class="px-4 py-3 text-gray-300 max-w-xs truncate" title="${skillString}">${skillString}</td>
          <td class="px-4 py-3 max-w-md">${generateMapTags(quest.mapIds)}</td>
       </tr>
      `;
        }).join('');
    }

    // Hàm lọc tìm kiếm
    function filterTable() {
        const keyword = removeVietnameseTones(document.getElementById('search-input').value.toLowerCase().trim());
        const selectedElementKey = document.getElementById('element-filter').value; // 'earth', 'water', v.v...

        // Chuyển đổi từ key tiếng Anh sang tên tiếng Việt tương ứng trong JSON dữ liệu gốc
        const targetDbElementName = provinceMapping[selectedElementKey] || "";

        const filtered = groupedQuests.filter(quest => {
            const matchKeyword = removeVietnameseTones(quest.name.toLowerCase()).includes(keyword);
            const matchElement = targetDbElementName === "" || quest.elementName === targetDbElementName;
            return matchKeyword && matchElement;
        });

        // Giới hạn hiển thị 150 dòng để tối ưu UI mượt mà
        renderTable(filtered.slice(0, 150));
    }

    // Chạy ứng dụng
    init();
</script>
