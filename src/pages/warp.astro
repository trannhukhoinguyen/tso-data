---
import Layout from '../layouts/Layout.astro';
// Import trực tiếp dữ liệu JSON tại Server-side để truyền xuống Client
import warpJsonUrl from '../data/warps.json?url';
---

<Layout title="Tra cứu NPC - TS Online">

    <main class="max-w-7xl mx-auto p-4">
        <h1 class="text-2xl font-bold mb-4">Danh sách Warp ID</h1>

        <div class="flex flex-col md:flex-row gap-4 mb-6">
            <input
                    type="text"
                    id="search-input"
                    placeholder="Nhập tên NPC hoặc ID..."
                    class="flex-1 bg-slate-800 text-white border border-gray-700 rounded px-4 py-2 focus:outline-none focus:border-blue-500"
            />

            <select
                    id="element-filter"
                    class="bg-slate-800 text-white border border-gray-700 rounded px-4 py-2 focus:outline-none focus:border-blue-500"
            >
                <option value="">Tất cả hệ</option>
                <option value="Địa">Địa</option>
                <option value="Thủy">Thủy</option>
                <option value="Hỏa">Hỏa</option>
                <option value="Phong">Phong</option>
            </select>
        </div>

        <div id="warp-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        </div>

        <div id="no-result" class="text-center text-gray-400 py-8 hidden">
            Không tìm thấy NPC phù hợp.
        </div>
    </main>
</Layout>

<script define:vars={{ warpJsonUrl }}>
    let groupedWarps = [];
    // Mảng màu đan xen dành cho các thẻ Map ID
    const tagColors = [
        'bg-gray-700 text-gray-200 border-gray-600',
        'bg-slate-700 text-slate-200 border-slate-600',
        'bg-zinc-700 text-zinc-200 border-zinc-600',
        'bg-neutral-700 text-neutral-200 border-neutral-600'
    ];

    // Bản đồ mapping giữa Value trên UI và Tên Hệ trong database JSON
    const elementMapping = {
        'earth': 'Địa',
        'water': 'Thủy',
        'fire': 'Hỏa',
        'wind': 'Phong',
        'mind': 'Tâm'
    };

    function removeVietnameseTones(str) {
        return str.normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .replace(/đ/g, "d").replace(/Đ/g, "D");
    }

    // Khởi tạo tải dữ liệu và gộp các record trùng tên
    async function init() {
        try {
            const response = await fetch(warpJsonUrl);
            const rawData = await response.json();

            // Sử dụng Map để gộp các NPC trùng tên
            const warpMap = new Map();
            rawData.forEach(warp => {
                // Lấy danh sách ID bản đồ từ mảng locations của record này
                const currentMapIds = warp.locations ? warp.locations.map(loc => loc.mapId) : [];

                if (warpMap.has(warp.name)) {
                    // Nếu đã tồn tại NPC trùng tên, tiến hành gộp Map ID
                    const existing = warpMap.get(warp.name);
                    currentMapIds.forEach(id => {
                        if (!existing.mapIds.includes(id)) {
                            existing.mapIds.push(id);
                        }
                    });
                } else {
                    // Nếu chưa có, tạo bản ghi gộp mới
                    warpMap.set(warp.name, {
                        name: warp.name,
                        elementName: warp.elementName || 'Vô',
                        level: warp.level,
                        hp: warp.hp,
                        sp: warp.sp,
                        skills: warp.skills || [],
                        mapIds: currentMapIds
                    });
                }
            });

            // Chuyển Map thành mảng để thao tác tìm kiếm / hiển thị
            groupedWarps = Array.from(warpMap.values());

            // ĐỌC QUERY PARAM từ URL (?element=...)
            const urlParams = new URLSearchParams(window.location.search);
            const elementParam = urlParams.get('element'); // Ví dụ: 'water'

            if (elementParam && elementMapping[elementParam]) {
                // Gán ngược value vào thẻ select trên UI
                document.getElementById('element-filter').value = elementParam;
            }

            // Gọi hàm filterTable lần đầu để vừa hiển thị vừa áp dụng bộ lọc từ URL (nếu có)
            filterTable();

            // Kích hoạt lắng nghe sự kiện khi user tương tác thủ công
            document.getElementById('search-input').addEventListener('input', filterTable);
            document.getElementById('element-filter').addEventListener('change', filterTable);

        } catch (error) {
            console.error("Lỗi khi load dữ liệu NPC:", error);
            document.getElementById('warp-table-body').innerHTML = `<tr><td colspan="7" class="text-center py-8 text-red-400">Không thể tải dữ liệu.</td></tr>`;
        }
    }

    // Hàm sinh chuỗi các tag màu đan xen cho Map ID
    function generateMapTags(mapIds) {
        if (!mapIds || mapIds.length === 0) {
            return `<span class="text-xs text-gray-500 italic">Không rõ nơi bắt</span>`;
        }

        return mapIds.map((id, index) => {
            const colorClass = tagColors[index % tagColors.length];
            return `<span class="inline-block text-xs font-mono px-2 py-0.5 rounded border ${colorClass} mr-1 mb-1 shadow-sm">${id}</span>`;
        }).join('');
    }

    // Hàm render dữ liệu mảng vào thẻ <tbody>
    function renderTable(list) {
        const tbody = document.getElementById('warp-table-body');
        const noResult = document.getElementById('no-result');

        if (list.length === 0) {
            tbody.innerHTML = '';
            noResult.classList.remove('hidden');
            return;
        }
        noResult.classList.add('hidden');
        tbody.innerHTML = list.map(warp => {
            // Định màu sắc riêng cho chữ của hệ tương ứng
            let elementColor = 'text-amber-400'; // Địa
            if (warp.elementName === 'Thủy') elementColor = 'text-blue-400';
            if (warp.elementName === 'Hỏa') elementColor = 'text-red-400';
            if (warp.elementName === 'Phong') elementColor = 'text-green-400';
            if (warp.elementName === 'Tâm') elementColor = 'text-purple-400'; // Thêm màu cho hệ Tâm

            const skillString = warp.skills.length > 0
                ? warp.skills.map(s => s.name).join(', ')
                : '<span class="text-gray-600">-</span>';

            return `
        <tr class="hover:bg-slate-800 transition-colors">
          <td class="px-4 py-3 font-semibold text-yellow-400">${warp.name}</td>
          <td class="px-4 py-3 font-medium ${elementColor}">${warp.elementName}</td>
          <td class="px-4 py-3 text-center">${warp.level}</td>
          <td class="px-4 py-3 text-center text-emerald-400">${warp.hp.toLocaleString()}</td>
          <td class="px-4 py-3 text-center text-cyan-400">${warp.sp.toLocaleString()}</td>
          <td class="px-4 py-3 text-gray-300 max-w-xs truncate" title="${skillString}">${skillString}</td>
          <td class="px-4 py-3 max-w-md">${generateMapTags(warp.mapIds)}</td>
       </tr>
      `;
        }).join('');
    }

    // Hàm lọc tìm kiếm
    function filterTable() {
        const keyword = removeVietnameseTones(document.getElementById('search-input').value.toLowerCase().trim());
        const selectedElementKey = document.getElementById('element-filter').value; // 'earth', 'water', v.v...

        // Chuyển đổi từ key tiếng Anh sang tên tiếng Việt tương ứng trong JSON dữ liệu gốc
        const targetDbElementName = elementMapping[selectedElementKey] || "";

        const filtered = groupedWarps.filter(warp => {
            const matchKeyword = removeVietnameseTones(warp.name.toLowerCase()).includes(keyword);
            const matchElement = targetDbElementName === "" || warp.elementName === targetDbElementName;
            return matchKeyword && matchElement;
        });

        // Giới hạn hiển thị 150 dòng để tối ưu UI mượt mà
        renderTable(filtered.slice(0, 150));
    }

    // Chạy ứng dụng
    init();
</script>
